{
  "info": {
    "name": "ZeroGap Backend",
    "_postman_id": "f2aa85f4-2dd1-4ef0-bd84-e4976f3843ce",
    "description": "API collection for ZeroGap backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "token", "value": "" },
    { "key": "sessionId", "value": "" },
    { "key": "resumeId", "value": "" },
    { "key": "roadmapId", "value": "" },
    { "key": "stageId", "value": "" },
    { "key": "taskId", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student@example.com\",\n  \"password\": \"StrongPassword123\",\n  \"fullName\": \"Alex Rivera\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register"
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student@example.com\",\n  \"password\": \"StrongPassword123\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/auth/me"
          }
        }
      ]
    },
    {
      "name": "Profile",
      "item": [
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/profile"
          }
        },
        {
          "name": "Complete Onboarding",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"profile\": {\n    \"college_name\": \"ZeroGap University\",\n    \"degree\": \"B.Tech CSE\",\n    \"graduation_year\": 2027,\n    \"learning_style\": \"project-based\",\n    \"time_availability_hours\": 3\n  },\n  \"target_role\": {\n    \"job_title\": \"Full Stack Developer\",\n    \"experience_level\": \"fresher\"\n  },\n  \"skills\": [\n    { \"skill_name\": \"JavaScript\", \"proficiency_level\": 70 },\n    { \"skill_name\": \"React\", \"proficiency_level\": 60 }\n  ]\n}"
            },
            "url": "{{baseUrl}}/api/profile/onboarding"
          }
        },
        {
          "name": "Sync GitHub",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"accessToken\": \"github-user-access-token\"\n}" },
            "url": "{{baseUrl}}/api/profile/github/sync"
          }
        }
      ]
    },
    {
      "name": "Skill Gap",
      "item": [
        {
          "name": "Analyze Skill Gap",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{}" },
            "url": "{{baseUrl}}/api/skill-gap/analyze"
          }
        },
        {
          "name": "Latest Skill Gap",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/skill-gap/latest"
          }
        }
      ]
    },
    {
      "name": "Roadmap",
      "item": [
        {
          "name": "Generate Roadmap",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/roadmap/generate"
          }
        },
        {
          "name": "Get Active Roadmap",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/roadmap/active"
          }
        },
        {
          "name": "Complete Task",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/roadmap/task/{{taskId}}/complete"
          }
        }
      ]
    },
    {
      "name": "Resume",
      "item": [
        {
          "name": "Generate Resume",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/resume/generate"
          }
        },
        {
          "name": "Get Latest Resume",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/resume/latest"
          }
        },
        {
          "name": "Export Resume PDF",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/resume/{{resumeId}}/export-pdf"
          }
        }
      ]
    },
    {
      "name": "Mentor",
      "item": [
        {
          "name": "Create Session",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Career Coaching\",\n  \"context_type\": \"general\"\n}" },
            "url": "{{baseUrl}}/api/mentor/sessions"
          }
        },
        {
          "name": "Chat",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"session_id\": \"{{sessionId}}\",\n  \"message\": \"What should I focus on this week to improve my score?\"\n}" },
            "url": "{{baseUrl}}/api/mentor/chat"
          }
        }
      ]
    },
    {
      "name": "Jobs",
      "item": [
        {
          "name": "Refresh Market",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"role\": \"Full Stack Developer\"\n}" },
            "url": "{{baseUrl}}/api/jobs/refresh"
          }
        },
        {
          "name": "Get Matches",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/hire-me/matches"
          }
        }
      ]
    },
    {
      "name": "Tracker and XP",
      "item": [
        {
          "name": "Log Activity",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"action\": \"Solved two roadmap exercises\",\n  \"time_spent_minutes\": 90,\n  \"xp_earned\": 40\n}" },
            "url": "{{baseUrl}}/api/tracker/log"
          }
        },
        {
          "name": "Get XP Stats",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/xp/stats"
          }
        }
      ]
    }
  ]
}
